{
  "manifestVersion": 1,
  "id": "git-save-load",
  "name": "Git Save/Load",
  "version": "1.0.0",
  "description": "Git 存档与读档。支持一键存档、版本历史浏览、分支管理、远程推送/拉取。",
  "trust": "full-access",
  "minAppVersion": "0.82.0",
  "contributes": {
    "widget": {
      "title": "Git Save/Load",
      "icon": "<svg viewBox='0 0 93 83' fill='currentColor' stroke='none' xmlns='http://www.w3.org/2000/svg'><path d='M 33.5 10 Q 42.1 8.9 44 14.5 L 45 17.5 L 42 19 L 41 15 Q 38.9 13.4 33.5 14 Q 24.7 17.7 20 25.5 L 13 40.5 L 12 53.5 L 16.5 61 L 24.5 62 Q 31 60.5 34 55.5 L 36 49.5 L 29 45.5 Q 31 41 39.5 43 L 42 48.5 L 41 49.5 L 41 61.5 L 40 62.5 Q 40.9 70.9 39 75 L 36 73.5 L 37 58.5 L 31.5 63 L 24.5 66 L 19.5 66 L 15.5 65 L 10 59.5 L 8 52.5 L 8 47.5 L 11 34.5 L 16 24.5 L 24.5 15 L 33.5 10 Z'/><path d='M 57.5 17 Q 59.8 16.3 59 18.5 Q 57.5 21.5 56 18.5 L 57.5 17 Z'/><path d='M 78.5 18 Q 81.1 17.2 80 20.5 Q 77.1 25.4 78 33 L 85 32 L 83.5 35 L 77 37 L 76 56.5 L 75 57.5 L 75 69.5 Q 77 73 79 68.5 L 80.5 66 L 81 67.5 L 77.5 74 Q 72.8 74.8 72 71.5 L 72 53.5 L 73 52.5 L 73 43.5 L 74 38 Q 70.2 39 69 36.5 Q 68.3 34.3 70.5 35 L 75 32.5 L 76 20.5 L 78.5 18 Z'/><path d='M 54 31 L 58 32.5 L 59 43.5 L 58 44.5 L 58 52.5 L 56 62.5 L 57 62.5 L 58.5 59 L 59 62.5 L 54.5 71 L 52.5 72 L 51 68.5 L 54 58.5 L 56 34.5 L 54 31 Z'/></svg>",
      "route": "/widget"
    },
    "configuration": {
      "type": "object",
      "properties": {
        "repoPath": {
          "type": "string",
          "default": "",
          "description": "管理的 Git 仓库路径"
        },
        "stashMode": {
          "type": "string",
          "default": "untracked",
          "enum": ["normal", "untracked", "all"],
          "description": "暂存模式"
        },
        "pushMode": {
          "type": "string",
          "default": "normal",
          "enum": ["normal", "force-with-lease", "force"],
          "description": "推送模式"
        },
        "pullMode": {
          "type": "string",
          "default": "merge",
          "enum": ["merge", "rebase", "ff-only"],
          "description": "拉取模式"
        },
        "defaultDiffMode": {
          "type": "string",
          "default": "detail",
          "enum": ["detail", "simple"],
          "description": "默认 diff 显示模式"
        },
        "theme": {
          "type": "string",
          "default": "light",
          "enum": ["light", "dark"],
          "description": "主题"
        }
      }
    }
  }
}
